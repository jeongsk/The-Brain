# Active engine provider
# Options: ollama, openai, vllm, lmstudio, llamacpp
LLM_ENGINE=openai

# Provider URLs
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
VLLM_BASE_URL=http://localhost:8000/v1
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API key
OPENAI_API_KEY=sk-local-test-key

# Models
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-5.4-mini

# Reranker config (optional — leave empty to use default model inside container)
RERANKER_BASE_URL=
RERANKER_MODEL=

# Model Settings & Tuning
LLM_NUM_CTX=32768
LLM_TIMEOUT=7200
LLM_MAX_ASYNC=1

EMBEDDING_DIM=2560
MAX_EMBED_TOKENS=8192
EMBEDDING_TIMEOUT=300
EMBEDDING_MAX_ASYNC=1

# Document Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP_SIZE=100

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j

# Internal paths (mapped to volume)
WORKING_DIR=/app/data/rag_storage
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/output
PARSER=mineru
